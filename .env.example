# Copy to .env and fill in real secrets before deploying.

# --- core ---
SECRET_KEY=change-me-to-a-long-random-string
API_BASE_URL=http://localhost
CORS_ORIGINS=http://localhost:3000

# --- database (compose service name "db") ---
POSTGRES_USER=genclear
POSTGRES_PASSWORD=change-me
POSTGRES_DB=genclear
DATABASE_URL=postgresql+asyncpg://genclear:change-me@db:5432/genclear
SYNC_DATABASE_URL=postgresql+psycopg2://genclear:change-me@db:5432/genclear

# --- redis / celery (compose service name "redis") ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- storage (MinIO in Docker; set STORAGE_BACKEND=local to skip S3) ---
STORAGE_BACKEND=s3
DATA_DIR=/data
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=genclear
S3_SECRET_KEY=change-me-minio-secret
S3_BUCKET=genclear
S3_REGION=us-east-1
RESULT_TTL_HOURS=48

# --- limits ---
MAX_UPLOAD_BYTES=1073741824
MAX_DURATION_SEC=600
MAX_PENDING_JOBS_PER_USER=5

# --- processing ---
TOOL_BIN=/opt/veo/GeminiWatermarkTool-Video
TOOL_EXTRA_ARGS=
JOB_TIMEOUT_SEC=1800
